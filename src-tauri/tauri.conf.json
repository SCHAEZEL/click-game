{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "迷宫猎手",
  "version": "0.1.0",
  "identifier": "com.clickers.maomao",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devtools": true
  },
  "app": {
    "windows": [
      {
        "title": "迷宫猎手 - 猫国建设者",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
